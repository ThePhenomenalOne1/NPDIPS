{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/fib/create-payment",
      "dest": "/api/fib-create-payment.js"
    },
    {
      "src": "/api/fib/payment-status",
      "dest": "/api/fib-payment-status.js"
    },
    {
      "src": "/api/fib/payment-callback",
      "dest": "/api/fib-payment-callback.js"
    },
    {
      "src": "/api/send-otp",
      "dest": "/api/send-otp.js"
    },
    {
      "src": "/api/verify-otp",
      "dest": "/api/verify-otp.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
